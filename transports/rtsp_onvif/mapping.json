{
  "protocol_type": "RTSP_ONVIF_CGI",
  "device_platform": "FT-C600",
  "version": "1.0",
  "base_url": "http://{device_ip}/api/v1",
  "commands": [
    {
      "name": "SYS_HANDSHAKE",
      "definition": "system.json",
      "endpoint": "/system/unlock",
      "method": "POST",
      "auth_required": true,
      "description": "Session-based authentication (replaces 0xA0 Magic Key)"
    },
    {
      "name": "DEVICE_INFO",
      "definition": "system.json",
      "endpoint": "/system/device_info",
      "method": "GET",
      "onvif_action": "GetDeviceInformation",
      "description": "Standard ONVIF Device Management or Custom CGI"
    },
    {
      "name": "AE_STATUS",
      "definition": "imaging.json",
      "endpoint": "/imaging/ae_status",
      "method": "GET",
      "onvif_action": "GetImagingSettings",
      "description": "Retrieve exposure parameters via HTTP JSON or ONVIF SOAP"
    },
    {
      "name": "GI_V5_CONFIG",
      "definition": "imaging.json",
      "endpoint": "/imaging/gi_v5_config",
      "method": "PATCH",
      "description": "Update algorithm flags (replaces XU 0x97)"
    },
    {
      "name": "BARCODE_RESULT",
      "definition": "barcode.json",
      "endpoint": "/barcode/latest",
      "method": "GET",
      "stream_path": "rtsp://{device_ip}/metadata",
      "description": "Fetch result via polling or RTSP Metadata Stream (ONVIF Profile M)"
    },
    {
      "name": "SCAN_MODE_SET",
      "definition": "barcode.json",
      "endpoint": "/barcode/config",
      "method": "PUT",
      "description": "Update scanner engine settings"
    },
    {
      "name": "FILE_UPLOAD",
      "definition": "file_transfer.json",
      "endpoint": "/maintenance/upload",
      "method": "POST",
      "content_type": "multipart/form-data",
      "description": "Firmware or LUT upload (replaces chunked XU 0xBB/0xBD)"
    },
    {
      "name": "RAW_IMAGE_SNAPSHOT",
      "definition": "imaging.json",
      "endpoint": "/imaging/snapshot/raw",
      "method": "GET",
      "description": "Retrieve full NV12 frame (replaces chunked XU 0x92)"
    }
  ]
}