{
  "module": "Barcode",
  "version": "3.0",
  "description": "Barcode scanning control, trigger, and result retrieval",
  "payload_size": 60,
  "commands": [
    {
      "command_name": "DECODER_PAUSE_STATUS",
      "command_id": "0x0A",
      "direction": "GET",
      "desc": "Query whether barcode decoder is paused",
      "get_fields": [
        { "name": "is_paused", "offset": 0, "type": "uint8", "desc": "0=Running, 1=Paused" }
      ]
    },
    {
      "command_name": "DECODER_PAUSE",
      "command_id": "0x0B",
      "direction": "SET",
      "desc": "Pause barcode decoding",
      "set_fields": [
        { "name": "echo", "offset": 0, "type": "uint8", "desc": "Command ID (0x0B)" }
      ]
    },
    {
      "command_name": "DECODER_RESUME",
      "command_id": "0x0C",
      "direction": "SET",
      "desc": "Resume barcode decoding",
      "set_fields": [
        { "name": "echo", "offset": 0, "type": "uint8", "desc": "Command ID (0x0C)" }
      ]
    },
    {
      "command_name": "SCAN_MODE",
      "command_id": "0x80",
      "direction": "GET+SET",
      "desc": "Set or query scanning mode",
      "set_fields": [
        { "name": "echo",      "offset": 0, "type": "uint8", "desc": "Command ID (0x80)" },
        { "name": "size",      "offset": 1, "type": "uint8", "desc": "Payload size" },
        { "name": "scan_mode", "offset": 2, "type": "uint8", "desc": "0=Continuous, 1=SingleTrigger, 2=HoldTrigger" }
      ],
      "get_fields": [
        { "name": "echo",      "offset": 0, "type": "uint8", "desc": "Command ID echo (0x80)" },
        { "name": "size",      "offset": 1, "type": "uint8", "desc": "Payload size (1)" },
        { "name": "scan_mode", "offset": 2, "type": "uint8", "desc": "0=Continuous, 1=SingleTrigger, 2=HoldTrigger" }
      ]
    },
    {
      "command_name": "SOFTWARE_TRIGGER",
      "command_id": "0x93",
      "direction": "GET+SET",
      "desc": "Fire a single barcode scan from host",
      "set_fields": [
        { "name": "echo",   "offset": 0, "type": "uint8", "desc": "Command ID (0x93)" },
        { "name": "size",   "offset": 1, "type": "uint8", "desc": "Payload size" },
        { "name": "action", "offset": 2, "type": "uint8", "desc": "0x01=Fire software trigger" }
      ],
      "get_fields": [
        { "name": "echo",           "offset": 0, "type": "uint8", "desc": "Command ID echo (0x93)" },
        { "name": "scan_mode",      "offset": 1, "type": "uint8", "desc": "Current scan mode" },
        { "name": "trigger_state",  "offset": 2, "type": "uint8", "desc": "Always 0 (edge-triggered)" },
        { "name": "trigger_source", "offset": 3, "type": "uint8", "desc": "0=None, 1=HW, 2=SW" }
      ]
    },
    {
      "command_name": "BARCODE_RESULT",
      "command_id": "0x90",
      "direction": "GET+SET",
      "desc": "Queue control and primary result retrieval with text preview",
      "set_fields": [
        { "name": "echo",   "offset": 0, "type": "uint8", "desc": "Command ID (0x90)" },
        { "name": "size",   "offset": 1, "type": "uint8", "desc": "Payload size" },
        { "name": "action", "offset": 2, "type": "uint8", "desc": "0x00=Query, 0x01=Dequeue, 0x02=Flush, 0x03=Snapshot" }
      ],
      "get_fields": [
        { "name": "echo",         "offset": 0,  "type": "uint8",  "desc": "Command ID echo (0x90)" },
        { "name": "queue_count",  "offset": 1,  "type": "uint8",  "desc": "Number of results pending in device FIFO" },
        { "name": "seq_number",   "offset": 2,  "type": "uint32", "desc": "Incremental sequence ID (LE)" },
        { "name": "status",       "offset": 6,  "type": "uint8",  "desc": "0=Empty, 1=Valid data" },
        { "name": "format_len",   "offset": 7,  "type": "uint8",  "desc": "Format string length" },
        { "name": "format_name",  "offset": 8,  "type": "char",   "size": 15, "desc": "Symbology name (null-terminated)" },
        { "name": "text_len",     "offset": 23, "type": "uint16", "desc": "Total barcode text length (LE)" },
        { "name": "text_preview", "offset": 25, "type": "char",   "size": 34, "desc": "First 34 bytes of barcode data" },
        { "name": "flags",        "offset": 59, "type": "uint8",  "desc": "bit0=has_more_chunks, bit1=scan_active" }
      ]
    },
    {
      "command_name": "BARCODE_EXT_TEXT",
      "command_id": "0x91",
      "direction": "GET+SET",
      "desc": "Read full barcode text in 54-byte chunks (for results >34 bytes)",
      "set_fields": [
        { "name": "echo",        "offset": 0, "type": "uint8",  "desc": "Command ID (0x91)" },
        { "name": "size",        "offset": 1, "type": "uint8",  "desc": "Payload size" },
        { "name": "chunk_index", "offset": 2, "type": "uint16", "desc": "Chunk index to fetch (LE)" }
      ],
      "get_fields": [
        { "name": "echo",           "offset": 0, "type": "uint8",  "desc": "Command ID echo (0x91)" },
        { "name": "chunk_index",    "offset": 1, "type": "uint16", "desc": "Chunk index echo (LE)" },
        { "name": "total_text_len", "offset": 3, "type": "uint16", "desc": "Total text length (LE)" },
        { "name": "chunk_size",     "offset": 5, "type": "uint8",  "desc": "Bytes in this chunk (0-54)" },
        { "name": "text_data",      "offset": 6, "type": "char",   "size": 54, "desc": "Text data (offset = chunk_index * 54)" }
      ]
    },
    {
      "command_name": "BARCODE_EXT_RESULT",
      "command_id": "0x95",
      "direction": "GET+SET",
      "desc": "Extended barcode result with corner coordinates and ROI metadata (v2+ only)",
      "note": "Requires UVC_ALGORITHM_USE_STATIC_LIBRARY_VERSION >= 2. Filled by roi_capture_fill_ext_result_response()",
      "set_fields": [
        { "name": "echo", "offset": 0, "type": "uint8", "desc": "Command ID (0x95) — query trigger" }
      ],
      "get_fields": [
        { "name": "echo",           "offset": 0,  "type": "uint8",  "desc": "Command ID echo (0x95)" },
        { "name": "result_status",  "offset": 1,  "type": "uint8",  "desc": "0=Empty, 1=Valid" },
        { "name": "corner0_x",     "offset": 2,  "type": "int16",  "desc": "Corner 0 X (LE)" },
        { "name": "corner0_y",     "offset": 4,  "type": "int16",  "desc": "Corner 0 Y (LE)" },
        { "name": "corner1_x",     "offset": 6,  "type": "int16",  "desc": "Corner 1 X (LE)" },
        { "name": "corner1_y",     "offset": 8,  "type": "int16",  "desc": "Corner 1 Y (LE)" },
        { "name": "corner2_x",     "offset": 10, "type": "int16",  "desc": "Corner 2 X (LE)" },
        { "name": "corner2_y",     "offset": 12, "type": "int16",  "desc": "Corner 2 Y (LE)" },
        { "name": "corner3_x",     "offset": 14, "type": "int16",  "desc": "Corner 3 X (LE)" },
        { "name": "corner3_y",     "offset": 16, "type": "int16",  "desc": "Corner 3 Y (LE)" },
        { "name": "orientation",    "offset": 18, "type": "int16",  "desc": "Barcode orientation (LE)" },
        { "name": "ec_level_len",   "offset": 20, "type": "uint8",  "desc": "EC level string length" },
        { "name": "ec_level",       "offset": 21, "type": "char",   "size": 15, "desc": "EC level string (null-terminated)" },
        { "name": "is_2d",          "offset": 36, "type": "uint8",  "desc": "0=1D barcode, 1=2D code" },
        { "name": "roi_data_ready", "offset": 37, "type": "uint8",  "desc": "1=ROI JPEG available via 0x96" },
        { "name": "roi_jpeg_size",  "offset": 38, "type": "uint32", "desc": "ROI JPEG size in bytes (LE)" },
        { "name": "roi_width",      "offset": 42, "type": "uint16", "desc": "ROI image width (LE)" },
        { "name": "roi_height",     "offset": 44, "type": "uint16", "desc": "ROI image height (LE)" },
        { "name": "paired_seq",     "offset": 46, "type": "uint32", "desc": "Paired sequence number (LE)" },
        { "name": "reserved",       "offset": 50, "type": "uint8",  "size": 10, "desc": "Reserved (zeros)" }
      ]
    }
  ]
}
